{
  "name": "meal-planner-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "mkdir -p public/fonts && cp node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf public/fonts/ && npx expo export --platform web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:check": "vitest run lib/i18n/validate.test.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/noto-emoji": "^0.4.6",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.0.0",
    "@tanstack/react-query": "^5.51.0",
    "expo": "^55.0.0",
    "expo-auth-session": "~55.0.0",
    "expo-blur": "~55.0.0",
    "expo-constants": "~55.0.0",
    "expo-crypto": "~55.0.0",
    "expo-font": "~55.0.0",
    "expo-haptics": "^55.0.0",
    "expo-image": "~55.0.0",
    "expo-image-picker": "~55.0.0",
    "expo-keep-awake": "~55.0.0",
    "expo-linear-gradient": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "expo-system-ui": "~55.0.0",
    "expo-web-browser": "~55.0.0",
    "firebase": "^12.0.0",
    "nativewind": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.85.0",
    "react-native-css-interop": "^0.2.1",
    "react-native-gesture-handler": "~2.31.0",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.0",
    "react-native-worklets-core": "^1.6.2",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@biomejs/biome": "^2.3.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=3.0.0 <3.1.4": ">=3.1.4",
